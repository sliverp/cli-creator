{
  "name": "@cli-creator/clix",
  "version": "0.1.0",
  "description": "Build and publish installable CLIs from API documents.",
  "license": "MIT",
  "bin": {
    "clix": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clix": "tsx src/index.ts --",
    "build": "tsup src/index.ts --format cjs --target node20 --clean --out-dir dist --dts --shims",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
